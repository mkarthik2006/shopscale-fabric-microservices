{
  "realm": "shopscale",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      { "name": "ROLE_USER", "description": "Standard marketplace user" },
      { "name": "ROLE_ADMIN", "description": "Platform administrator" }
    ]
  },
  "clients": [
    {
      "clientId": "shopscale-gateway",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:9080/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:9080"],
      "defaultClientScopes": ["openid", "profile", "email", "roles"],
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "attributes": {
        "access.token.lifespan": "3600",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "email": "testuser@shopscale.dev",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Test@1234",
          "temporary": false
        }
      ],
      "realmRoles": ["ROLE_USER"]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@shopscale.dev",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Admin@1234",
          "temporary": false
        }
      ],
      "realmRoles": ["ROLE_USER", "ROLE_ADMIN"]
    }
  ]
}
